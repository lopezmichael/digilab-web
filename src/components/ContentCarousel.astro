---
// ContentCarousel.astro
// Contained carousel with centering, scroll arrows, and auto-scroll

interface Props {
  class?: string;
  autoScroll?: boolean;
  autoScrollSpeed?: number; // pixels per second
}

const {
  class: className,
  autoScroll = true,
  autoScrollSpeed = 30
} = Astro.props;

const carouselId = `carousel-${Math.random().toString(36).substr(2, 9)}`;
---

<div class:list={['content-carousel', className]} data-carousel-id={carouselId}>
  <button class="carousel-arrow carousel-arrow-left" aria-label="Scroll left">
    <i class="bi bi-chevron-left"></i>
  </button>

  <div class="carousel-viewport">
    <div class="carousel-track" id={carouselId}>
      <slot />
    </div>
    <div class="carousel-fade carousel-fade-left"></div>
    <div class="carousel-fade carousel-fade-right"></div>
  </div>

  <button class="carousel-arrow carousel-arrow-right" aria-label="Scroll right">
    <i class="bi bi-chevron-right"></i>
  </button>
</div>

<script define:vars={{ carouselId, autoScroll, autoScrollSpeed }}>
  const track = document.getElementById(carouselId);
  if (!track) throw new Error('Carousel track not found');

  const wrapper = track.closest('.content-carousel');
  const arrowLeft = wrapper.querySelector('.carousel-arrow-left');
  const arrowRight = wrapper.querySelector('.carousel-arrow-right');
  const fadeLeft = wrapper.querySelector('.carousel-fade-left');
  const fadeRight = wrapper.querySelector('.carousel-fade-right');

  let isAutoScrolling = autoScroll;
  let isPaused = false;
  let lastTime = 0;
  let animationId;

  // Check if content overflows the track
  const hasOverflow = () => track.scrollWidth > track.clientWidth + 1;

  // Update centering, arrows, and edge fades
  const update = () => {
    const overflows = hasOverflow();

    // Center items when they fit
    if (overflows) {
      track.classList.remove('carousel-centered');
    } else {
      track.classList.add('carousel-centered');
    }

    // Show/hide arrows + fades
    if (!overflows) {
      arrowLeft.classList.remove('visible');
      arrowRight.classList.remove('visible');
      fadeLeft.classList.remove('visible');
      fadeRight.classList.remove('visible');
      return;
    }

    const atStart = track.scrollLeft <= 2;
    const atEnd = track.scrollLeft >= track.scrollWidth - track.clientWidth - 2;

    arrowLeft.classList.toggle('visible', !atStart);
    arrowRight.classList.toggle('visible', !atEnd);
    fadeLeft.classList.toggle('visible', !atStart);
    fadeRight.classList.toggle('visible', !atEnd);
  };

  // Arrow click handlers
  const scrollStep = () => Math.min(track.clientWidth * 0.75, 600);

  arrowLeft.addEventListener('click', () => {
    isPaused = true;
    track.scrollBy({ left: -scrollStep(), behavior: 'smooth' });
    setTimeout(() => { isPaused = false; }, 3000);
  });

  arrowRight.addEventListener('click', () => {
    isPaused = true;
    track.scrollBy({ left: scrollStep(), behavior: 'smooth' });
    setTimeout(() => { isPaused = false; }, 3000);
  });

  track.addEventListener('scroll', update, { passive: true });

  // Auto-scroll animation
  const animate = (timestamp) => {
    if (!lastTime) lastTime = timestamp;
    const delta = timestamp - lastTime;
    lastTime = timestamp;

    if (isAutoScrolling && !isPaused) {
      const pixels = (autoScrollSpeed * delta) / 1000;
      track.scrollLeft += pixels;

      if (track.scrollLeft >= track.scrollWidth - track.clientWidth - 10) {
        track.scrollLeft = 0;
      }
    }

    animationId = requestAnimationFrame(animate);
  };

  // Pause on interaction
  const pauseAutoScroll = () => { isPaused = true; };
  const resumeAutoScroll = () => {
    setTimeout(() => { isPaused = false; }, 3000);
  };

  track.addEventListener('mouseenter', pauseAutoScroll);
  track.addEventListener('mouseleave', resumeAutoScroll);
  track.addEventListener('touchstart', pauseAutoScroll, { passive: true });
  track.addEventListener('touchend', resumeAutoScroll);
  track.addEventListener('wheel', () => {
    pauseAutoScroll();
    resumeAutoScroll();
  }, { passive: true });

  // Drag scrolling
  let isDragging = false;
  let startX = 0;
  let scrollStart = 0;

  track.addEventListener('mousedown', (e) => {
    if (!hasOverflow()) return;
    isDragging = true;
    startX = e.pageX;
    scrollStart = track.scrollLeft;
    track.style.cursor = 'grabbing';
    pauseAutoScroll();
  });

  window.addEventListener('mousemove', (e) => {
    if (!isDragging) return;
    e.preventDefault();
    const dx = e.pageX - startX;
    track.scrollLeft = scrollStart - dx;
  });

  window.addEventListener('mouseup', () => {
    if (isDragging) {
      isDragging = false;
      track.style.cursor = '';
      resumeAutoScroll();
    }
  });

  // Initialize
  update();
  window.addEventListener('resize', update);

  if (autoScroll) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!prefersReducedMotion.matches && hasOverflow()) {
      animationId = requestAnimationFrame(animate);
    }
  }

  // Cleanup
  document.addEventListener('astro:before-swap', () => {
    cancelAnimationFrame(animationId);
  });
</script>

<style>
  .content-carousel {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-2, 8px);
    max-width: var(--container-xl, 1280px);
    margin: 0 auto;
    padding: 0 var(--space-4, 16px);
  }

  .carousel-viewport {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .carousel-track {
    display: flex;
    gap: var(--space-4, 16px);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    padding: var(--space-4, 16px) var(--space-1, 4px);
    cursor: grab;

    /* Hide scrollbar */
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-track > :global(*) {
    flex-shrink: 0;
  }

  .carousel-track.carousel-centered {
    justify-content: center;
    cursor: default;
  }

  /* ===== Edge Fade Overlays ===== */
  .carousel-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 40px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 2;
  }

  .carousel-fade.visible {
    opacity: 1;
  }

  .carousel-fade-left {
    left: 0;
    background: linear-gradient(to right, var(--color-background, #f8f9fa), transparent);
  }

  .carousel-fade-right {
    right: 0;
    background: linear-gradient(to left, var(--color-background, #f8f9fa), transparent);
  }

  /* ===== Navigation Arrows ===== */
  .carousel-arrow {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border, #dee2e6);
    background: var(--color-surface, #ffffff);
    color: var(--color-primary, #0A3055);
    font-size: var(--font-size-lg, 18px);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s, color 0.2s, border-color 0.2s, box-shadow 0.2s;
  }

  .carousel-arrow.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .carousel-arrow:hover {
    color: var(--color-accent, #F7941D);
    border-color: var(--color-accent, #F7941D);
    box-shadow: 0 0 0 3px rgba(247, 148, 29, 0.15);
  }

  /* Mobile: hide arrows, swipe is intuitive */
  @media (max-width: 768px) {
    .content-carousel {
      padding: 0;
    }

    .carousel-arrow {
      display: none;
    }
  }

  /* ===== Dark Mode ===== */
  :global([data-theme="dark"]) .carousel-fade-left {
    background: linear-gradient(to right, var(--color-background-dark, #1a1a2e), transparent);
  }

  :global([data-theme="dark"]) .carousel-fade-right {
    background: linear-gradient(to left, var(--color-background-dark, #1a1a2e), transparent);
  }

  :global([data-theme="dark"]) .carousel-arrow {
    background: var(--color-surface-dark, #1e1e2e);
    border-color: var(--color-border-dark, #2a2a2a);
    color: var(--color-digital, #00c8ff);
  }

  :global([data-theme="dark"]) .carousel-arrow:hover {
    color: var(--color-accent, #F7941D);
    border-color: var(--color-accent, #F7941D);
    box-shadow: 0 0 0 3px rgba(247, 148, 29, 0.2);
  }
</style>
