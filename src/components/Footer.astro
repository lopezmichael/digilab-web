---
// Footer component with links
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-glow"></div>
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/brand/digivice.svg" alt="" class="footer-logo-icon" />
        <span>DigiLab</span>
      </a>
      <p class="footer-tagline">Track your local Digimon TCG scene</p>
      <div class="footer-social">
        <a href="https://discord.gg/digilab" target="_blank" rel="noopener" aria-label="Discord" class="social-link">
