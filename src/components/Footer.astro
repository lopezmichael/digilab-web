---
// Footer component with links
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/brand/digivice.svg" alt="" class="footer-logo-icon" />
        <span>DigiLab</span>
      </a>
      <p class="footer-tagline">Track your local Digimon TCG scene</p>
    </div>

    <div class="footer-links">
      <div class="footer-section">
        <h4>Product</h4>
        <a href="https://app.digilab.cards">App</a>
        <a href="/blog">Blog</a>
        <a href="/roadmap">Roadmap</a>
      </div>

      <div class="footer-section">
        <h4>Community</h4>
        <a href="https://discord.gg/digilab" target="_blank" rel="noopener">Discord</a>
        <a href="https://ko-fi.com/digilab" target="_blank" rel="noopener">Ko-fi</a>
      </div>

      <div class="footer-section">
        <h4>Resources</h4>
        <a href="/about">About</a>
        <a href="https://github.com/lopezmichael/digilab-app" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} DigiLab. Built with data and Digimon.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: white;
    padding: var(--space-12) 0 var(--space-6);
    margin-top: var(--space-16);
  }

  .footer-inner {
    display: grid;
    gap: var(--space-8);
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: white;
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-xl);
    text-decoration: none;
  }

  .footer-logo:hover {
    color: var(--color-accent);
  }

  .footer-logo-icon {
    width: 28px;
    height: 28px;
    filter: brightness(0) invert(1);
  }

  .footer-tagline {
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-8);
  }

  .footer-section h4 {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-4);
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-section a {
    display: block;
    color: white;
    text-decoration: none;
    padding: var(--space-1) 0;
    transition: color var(--transition-fast);
  }

  .footer-section a:hover {
    color: var(--color-accent);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--space-6);
    margin-top: var(--space-8);
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.5);
    font-size: var(--font-size-sm);
    margin: 0;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 2fr;
      grid-template-rows: auto auto;
    }

    .footer-brand {
      grid-column: 1;
    }

    .footer-links {
      grid-column: 2;
    }

    .footer-bottom {
      grid-column: 1 / -1;
    }
  }
</style>
