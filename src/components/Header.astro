            <g transform="matrix(1 0 0 1 -7.47 0)"><path style="stroke: currentColor; stroke-width: 1.5; fill: none;" transform=" translate(-4.53, -12)" d="M 4.33798 12.3775 C 4.54509 12.3775 4.71298 12.2096 4.71298 12.0025 C 4.71298 11.7953 4.54509 11.6275 4.33798 11.6275" stroke-linecap="round"/></g>
