---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About" description="Learn about DigiLab and how we're tracking the Digimon TCG competitive scene.">
  <Header />

  <main class="about-page">
    <!-- Hero Section -->
    <section class="about-hero">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <div class="hero-text">
          <h1>About DigiLab</h1>
          <p>Tracking the Digimon TCG competitive scene, one local at a time.</p>
        </div>
        <div class="hero-mascot">
          <div class="digivice-glow">
            <img src="/brand/digivice.svg" alt="" class="digivice-icon" />
          </div>
        </div>
      </div>
    </section>

    <div class="container">

      <section class="content-section">
        <h2>What is DigiLab?</h2>
        <p>
          DigiLab is a free tournament tracking platform for the Digimon Trading Card Game community.
          We help local scenes track player standings, analyze deck meta, and celebrate competitive play.
        </p>
        <p>
          Built by a data scientist who loves Digimon, DigiLab combines proper rating methodologies
          with a passion for the game to create something useful for the community.
        </p>
      </section>

      <section class="content-section">
        <h2>Features</h2>
        <ul>
          <li><strong>Player Ratings</strong> — Elo-based competitive ratings that reflect actual skill</li>
          <li><strong>Deck Meta Analysis</strong> — See what's winning in your area</li>
          <li><strong>Tournament History</strong> — Full results archive for all tracked events</li>
          <li><strong>Store Directory</strong> — Find local game stores running events</li>
          <li><strong>Scene Filtering</strong> — Focus on your local community or view globally</li>
        </ul>
      </section>

      <section class="content-section">
        <h2>Active Scenes</h2>
        <p>
          DigiLab is currently tracking tournaments in multiple regions across the US,
          with support for both local and online events.
        </p>
        <a href="https://app.digilab.cards" class="btn btn-primary">Explore the App</a>
      </section>

      <section class="content-section">
        <h2>Get Involved</h2>
        <p>
          Want to add your scene to DigiLab? Have feedback or feature requests?
          We'd love to hear from you.
        </p>
        <div class="link-buttons">
          <a href="https://discord.gg/digilab" class="btn btn-outline" target="_blank" rel="noopener">
            Join Discord
          </a>
          <a href="https://github.com/lopezmichael/digilab-app" class="btn btn-outline" target="_blank" rel="noopener">
            View on GitHub
          </a>
          <a href="https://ko-fi.com/digilab" class="btn btn-outline" target="_blank" rel="noopener">
            Support on Ko-fi
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===== Hero Section ===== */
  .about-hero {
    position: relative;
    padding: var(--space-12) 0 var(--space-16);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary-dark, #061a2e) 0%, var(--color-primary) 100%);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    z-index: -2;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .hero-text h1 {
    color: #ffffff;
    margin-bottom: var(--space-2);
  }

  .hero-text p {
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--font-size-lg);
    margin: 0;
  }

  .hero-mascot {
    flex-shrink: 0;
  }

  .digivice-glow {
    position: relative;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .digivice-glow::before {
    content: '';
    position: absolute;
    inset: -8px;
    background: radial-gradient(circle, rgba(0, 200, 255, 0.4) 0%, rgba(0, 200, 255, 0) 70%);
    border-radius: 50%;
    animation: digivice-pulse 3s ease-in-out infinite;
  }

  .digivice-icon {
    width: 56px;
    height: 56px;
    filter: brightness(0) invert(1);
    position: relative;
    z-index: 1;
  }

  @keyframes digivice-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  @media (max-width: 640px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
    }

    .hero-mascot {
      order: -1;
    }
  }

  /* ===== Main Content ===== */
  .about-page .container:not(.hero-content) {
    max-width: 800px;
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .content-section {
    margin-bottom: var(--space-10);
  }

  .content-section h2 {
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }

  .content-section p {
    margin-bottom: var(--space-4);
    line-height: var(--line-height-relaxed);
  }

  .content-section ul {
    list-style: none;
    padding: 0;
  }

  .content-section li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .content-section li:last-child {
    border-bottom: none;
  }

  .link-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  /* ===== Dark Mode ===== */
  :global([data-theme="dark"]) .content-section h2 {
    color: var(--color-digital);
  }
</style>
