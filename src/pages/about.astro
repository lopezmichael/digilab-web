---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About" description="Learn about DigiLab and how we're tracking the Digimon TCG competitive scene.">
  <Header />

  <main class="about-page">
    <!-- Hero Section -->
    <section class="about-hero">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <div class="hero-text">
          <h1>About DigiLab</h1>
          <p>Tracking the Digimon TCG competitive scene, one local at a time.</p>
        </div>
        <div class="hero-mascot">
          <div class="digivice-glow">
            <img src="/brand/digivice.svg" alt="" class="digivice-icon" />
          </div>
        </div>
      </div>
    </section>

    <div class="container">

      <section class="content-section">
        <h2>What is DigiLab?</h2>
        <p>
          DigiLab brings tournament data to your Digimon TCG community. Unlike global meta trackers,
          DigiLab is scene-based — it helps you understand how you stack up against the players
          you actually compete with, whether that's at your local game store or in online webcam tournaments.
        </p>
        <ul>
          <li>Track your tournament history and rating progression</li>
          <li>See what decks are performing in your scene's meta</li>
          <li>Compare performance across stores and online events</li>
          <li>Discover active tournament locations and communities</li>
        </ul>
      </section>

      <section class="content-section">
        <h2>Who is it For?</h2>
        <div class="audience-list">
          <p><strong>Players</strong> — Track your results, see your rating, and follow your local meta</p>
          <p><strong>Tournament Organizers</strong> — Upload results via Bandai TCG+ screenshots or get contributor access</p>
          <p><strong>Online Competitors</strong> — Limitless and webcam tournament data syncs automatically</p>
          <p><strong>Community Builders</strong> — Share community links, build store pages, and grow your scene</p>
        </div>
      </section>

      <section class="content-section">
        <h2>Features</h2>
        <ul>
          <li><strong>Player Ratings</strong> — Elo-based competitive ratings that reflect actual skill</li>
          <li><strong>Deck Meta Analysis</strong> — See what's winning in your area</li>
          <li><strong>Tournament History</strong> — Full results archive for all tracked events</li>
          <li><strong>Store Directory</strong> — Find local game stores running events</li>
          <li><strong>Scene Filtering</strong> — Focus on your local community or view globally</li>
        </ul>
      </section>

      <section class="content-section">
        <h2>Active Scenes</h2>
        <p>
          DigiLab tracks Digimon TCG communities across multiple scenes. Each scene has its own
          stores, players, and meta data. Want your area added? Check out the
          <a href="/organizers">For Organizers</a> page.
        </p>
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-value">8+</div>
            <div class="stat-label">Active Scenes</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">30+</div>
            <div class="stat-label">Active Stores</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">1,500+</div>
            <div class="stat-label">Players Tracked</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">400+</div>
            <div class="stat-label">Tournaments</div>
          </div>
        </div>
        <a href="https://app.digilab.cards" class="btn btn-primary">Explore the App</a>
      </section>

      <section class="content-section">
        <h2>Get Involved</h2>
        <p>
          Want to add your scene to DigiLab? Have feedback or feature requests?
          We'd love to hear from you.
        </p>
        <div class="link-buttons">
          <a href="https://discord.gg/digilab" class="btn btn-outline" target="_blank" rel="noopener">
            Join Discord
          </a>
          <a href="https://github.com/lopezmichael/digilab-app" class="btn btn-outline" target="_blank" rel="noopener">
            View on GitHub
          </a>
          <a href="https://ko-fi.com/digilab" class="btn btn-outline" target="_blank" rel="noopener">
            Support on Ko-fi
          </a>
        </div>
      </section>

      <section class="content-section disclaimer">
        <h2>Disclaimer</h2>
        <p>
          DigiLab is a fan-made community tool and is not affiliated with, endorsed by, or
          connected to Bandai Namco, Bandai Card Games, or any official Digimon TCG organization.
          All Digimon-related trademarks and copyrights belong to their respective owners.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===== Hero Section ===== */
  .about-hero {
    position: relative;
    padding: var(--space-12) 0 var(--space-16);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary-dark, #061a2e) 0%, var(--color-primary) 100%);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    z-index: -2;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .hero-text h1 {
    color: #ffffff;
    margin-bottom: var(--space-2);
  }

  .hero-text p {
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--font-size-lg);
    margin: 0;
  }

  .hero-mascot {
    flex-shrink: 0;
  }

  .digivice-glow {
    position: relative;
    width: 72px;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .digivice-glow::before {
    content: '';
    position: absolute;
    inset: -8px;
    background: radial-gradient(circle, rgba(0, 200, 255, 0.4) 0%, rgba(0, 200, 255, 0) 70%);
    border-radius: 50%;
    animation: digivice-pulse 3s ease-in-out infinite;
  }

  .digivice-icon {
    width: 56px;
    height: 56px;
    filter: brightness(0) invert(1);
    position: relative;
    z-index: 1;
  }

  @keyframes digivice-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  @media (max-width: 640px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
    }

    .hero-mascot {
      order: -1;
    }
  }

  /* ===== Main Content ===== */
  .about-page .container:not(.hero-content) {
    max-width: 800px;
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .content-section {
    margin-bottom: var(--space-10);
  }

  .content-section h2 {
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }

  .content-section p {
    margin-bottom: var(--space-4);
    line-height: var(--line-height-relaxed);
  }

  .content-section ul {
    list-style: none;
    padding: 0;
  }

  .content-section li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .content-section li:last-child {
    border-bottom: none;
  }

  .link-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  /* ===== Audience List ===== */
  .audience-list p {
    margin-bottom: var(--space-2);
  }

  .audience-list p:last-child {
    margin-bottom: 0;
  }

  /* ===== Stats Grid ===== */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin: var(--space-6) 0;
  }

  .stat-item {
    text-align: center;
    padding: var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .stat-value {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .stat-label {
    font-size: var(--font-size-sm);
    color: var(--color-muted);
    margin-top: var(--space-1);
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3);
    }

    .stat-item {
      padding: var(--space-3);
    }

    .stat-value {
      font-size: var(--font-size-xl);
    }
  }

  /* ===== Disclaimer ===== */
  .disclaimer {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-8);
    margin-top: var(--space-8);
  }

  .disclaimer p {
    color: var(--color-muted);
    font-size: var(--font-size-sm);
  }

  /* ===== Dark Mode ===== */
  :global([data-theme="dark"]) .content-section h2 {
    color: var(--color-digital);
  }

  :global([data-theme="dark"]) .stat-value {
    color: var(--color-digital);
  }

  :global([data-theme="dark"]) .stat-item {
    background: var(--color-surface);
    border-color: var(--color-border);
  }
</style>
