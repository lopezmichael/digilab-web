---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AgumonGuide from '../components/AgumonGuide.astro';
import DigiIcon from '../components/DigiIcon.astro';
---

<BaseLayout title="About" description="Learn about DigiLab and how we're tracking the Digimon TCG competitive scene.">
  <Header />

  <main class="about-page">
    <!-- Hero Section -->
    <section class="about-hero">
      <div class="hero-bg"></div>
      <div class="container hero-content">
        <div class="hero-text">
          <h1>About DigiLab</h1>
          <p>Tracking the Digimon TCG competitive scene, one local at a time.</p>
        </div>
        <div class="hero-mascot">
          <AgumonGuide pose="jumping" size="64px" />
        </div>
      </div>
    </section>

    <div class="container">

      <!-- Origin Story -->
      <section class="content-section origin-story">
        <h2>Why DigiLab Exists</h2>
        <p>
          The Digimon TCG has incredible local communities, but no easy way to track what's happening
          in them. Global meta sites tell you what's winning at Regionals, but not at your Saturday locals.
          Player skill is discussed but never measured. Tournament history lives in Discord messages and
          fading memories.
        </p>
        <p>
          DigiLab was built to change that — to give local scenes the same data-driven insights that
          larger competitive games take for granted. Every tournament matters. Every player's journey
          deserves to be tracked.
        </p>
      </section>

      <!-- What is DigiLab -->
      <section class="content-section">
        <h2>What is DigiLab?</h2>
        <p>
          DigiLab brings tournament data to your Digimon TCG community. Unlike global meta trackers,
          DigiLab is scene-based — it helps you understand how you stack up against the players
          you actually compete with, whether that's at your local game store or in online webcam tournaments.
        </p>
      </section>

      <!-- How It Works -->
      <section class="content-section how-it-works">
        <h2>How It Works</h2>
        <div class="flow-steps">
          <div class="flow-step">
            <div class="flow-icon">
              <DigiIcon name="camera" size="32px" />
            </div>
            <h3>1. Capture</h3>
            <p>Organizers screenshot results from Bandai TCG+ or submit via contributor tools</p>
          </div>
          <div class="flow-arrow">
            <DigiIcon name="arrow-right" size="24px" />
          </div>
          <div class="flow-step">
            <div class="flow-icon">
              <DigiIcon name="gear" size="32px" />
            </div>
            <h3>2. Process</h3>
            <p>Data is extracted, validated, and matched to player profiles</p>
          </div>
          <div class="flow-arrow">
            <DigiIcon name="arrow-right" size="24px" />
          </div>
          <div class="flow-step">
            <div class="flow-icon">
              <DigiIcon name="graph-up-arrow" size="32px" />
            </div>
            <h3>3. Analyze</h3>
            <p>Ratings update, meta shifts are tracked, and your history grows</p>
          </div>
        </div>
        <p class="flow-note">
          Online events from Limitless and webcam tournaments sync automatically.
        </p>
      </section>

      <!-- Who Is It For - Cards -->
      <section class="content-section">
        <h2>Who is it For?</h2>
        <div class="audience-cards">
          <div class="audience-card">
            <div class="audience-icon">
              <DigiIcon name="person" size="28px" />
            </div>
            <h3>Players</h3>
            <p>Track your results, see your rating, and follow your local meta</p>
          </div>
          <div class="audience-card">
            <div class="audience-icon">
              <DigiIcon name="clipboard-check" size="28px" />
            </div>
            <h3>Tournament Organizers</h3>
            <p>Upload results via Bandai TCG+ screenshots or get contributor access</p>
          </div>
          <div class="audience-card">
            <div class="audience-icon">
              <DigiIcon name="wifi" size="28px" />
            </div>
            <h3>Online Competitors</h3>
            <p>Limitless and webcam tournament data syncs automatically</p>
          </div>
          <div class="audience-card">
            <div class="audience-icon">
              <DigiIcon name="people" size="28px" />
            </div>
            <h3>Community Builders</h3>
            <p>Share community links, build store pages, and grow your scene</p>
          </div>
        </div>
      </section>

      <!-- Features - Cards -->
      <section class="content-section">
        <h2>Features</h2>
        <div class="feature-cards">
          <div class="feature-card">
            <DigiIcon name="graph-up-arrow" size="24px" />
            <h3>Player Ratings</h3>
            <p>Elo-based competitive ratings that reflect actual skill</p>
          </div>
          <div class="feature-card">
            <DigiIcon name="pie-chart" size="24px" />
            <h3>Deck Meta Analysis</h3>
            <p>See what's winning in your area</p>
          </div>
          <div class="feature-card">
            <DigiIcon name="trophy" size="24px" />
            <h3>Tournament History</h3>
            <p>Full results archive for all tracked events</p>
          </div>
          <div class="feature-card">
            <DigiIcon name="shop" size="24px" />
            <h3>Store Directory</h3>
            <p>Find local game stores running events</p>
          </div>
          <div class="feature-card">
            <DigiIcon name="globe" size="24px" />
            <h3>Scene Filtering</h3>
            <p>Focus on your local community or view globally</p>
          </div>
          <div class="feature-card">
            <DigiIcon name="link-45deg" size="24px" />
            <h3>Community Links</h3>
            <p>Share your scene's data with a single URL</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Active Scenes</h2>
        <p>
          DigiLab tracks Digimon TCG communities across multiple scenes. Each scene has its own
          stores, players, and meta data. Want your area added? Check out the
          <a href="/organizers">For Organizers</a> page.
        </p>
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-value" data-count="8" data-suffix="+">0</div>
            <div class="stat-label">Active Scenes</div>
          </div>
          <div class="stat-item">
            <div class="stat-value" data-count="30" data-suffix="+">0</div>
            <div class="stat-label">Active Stores</div>
          </div>
          <div class="stat-item">
            <div class="stat-value" data-count="1500" data-suffix="+" data-format="comma">0</div>
            <div class="stat-label">Players Tracked</div>
          </div>
          <div class="stat-item">
            <div class="stat-value" data-count="400" data-suffix="+">0</div>
            <div class="stat-label">Tournaments</div>
          </div>
        </div>
        <div class="section-cta">
          <a href="https://app.digilab.cards" class="btn btn-primary">Explore the App</a>
        </div>
      </section>

      <!-- Built By -->
      <section class="content-section built-by">
        <h2>Built By</h2>
        <div class="creator-card">
          <div class="creator-avatar">
            <div class="digivice-glow">
              <img src="/brand/digivice.svg" alt="" class="digivice-icon" />
            </div>
          </div>
          <div class="creator-info">
            <h3>atomshell</h3>
            <p class="creator-title">Creator & Developer</p>
            <p>
              A data scientist from North Texas who wanted to bring the same competitive tracking
              tools that other card games enjoy to the Digimon TCG community. DigiLab started as
              a passion project to help local scenes understand their meta and celebrate their players.
            </p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Get Involved</h2>
        <p>
          Want to add your scene to DigiLab? Have feedback or feature requests?
          We'd love to hear from you.
        </p>
        <div class="link-buttons">
          <a href="https://discord.gg/ABcjha7bHk" class="btn-social btn-discord" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
            </svg>
            Join Discord
          </a>
          <a href="https://github.com/lopezmichael/digilab-app" class="btn-social btn-github" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
          <a href="https://ko-fi.com/digilab" class="btn-social btn-kofi" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 3.011.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/>
            </svg>
            Support on Ko-fi
          </a>
        </div>
      </section>

      <section class="content-section disclaimer">
        <h2>Disclaimer</h2>
        <p>
          DigiLab is a fan-made community tool and is not affiliated with, endorsed by, or
          connected to Bandai Namco, Bandai Card Games, or any official Digimon TCG organization.
          All Digimon-related trademarks and copyrights belong to their respective owners.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===== Hero Section ===== */
  .about-hero {
    position: relative;
    padding: var(--space-12) 0 var(--space-16);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary-dark, #061a2e) 0%, var(--color-primary) 100%);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    z-index: -2;
  }

  .hero-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
  }

  .hero-text h1 {
    color: #ffffff;
    margin-bottom: var(--space-2);
  }

  .hero-text p {
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--font-size-lg);
    margin: 0;
  }

  .hero-mascot {
    flex-shrink: 0;
  }

  .hero-mascot {
    filter: drop-shadow(0 0 20px rgba(247, 148, 29, 0.4));
    transform: translate(-150px, 20px);
  }

  .hero-mascot :global(.agumon-dust) {
    left: 0%;
  }

  @media (max-width: 640px) {
    .hero-content {
      flex-direction: column;
      text-align: center;
    }

    .hero-mascot {
      order: -1;
      transform: translate(40px, 0);
    }
  }

  /* ===== Main Content ===== */
  .about-page .container:not(.hero-content) {
    max-width: 800px;
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .content-section {
    margin-bottom: var(--space-10);
  }

  .content-section h2 {
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }

  .content-section p {
    margin-bottom: var(--space-4);
    line-height: var(--line-height-relaxed);
  }

  .content-section ul {
    list-style: none;
    padding: 0;
  }

  .content-section li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .content-section li:last-child {
    border-bottom: none;
  }

  /* ===== Section CTA ===== */
  .section-cta {
    text-align: center;
    margin-top: var(--space-4);
  }

  .link-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
    justify-content: center;
  }

  /* ===== Social Buttons ===== */
  .btn-social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
    border: none;
  }

  .btn-social svg {
    flex-shrink: 0;
  }

  .btn-discord {
    background: #5865F2;
    color: #ffffff;
  }

  .btn-discord:hover {
    background: #4752c4;
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(88, 101, 242, 0.4);
  }

  .btn-github {
    background: #24292e;
    color: #ffffff;
  }

  .btn-github:hover {
    background: #1a1e22;
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(36, 41, 46, 0.4);
  }

  .btn-kofi {
    background: #FF5E5B;
    color: #ffffff;
  }

  .btn-kofi:hover {
    background: #e54542;
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255, 94, 91, 0.4);
  }

  /* ===== Origin Story ===== */
  .origin-story p {
    font-size: var(--font-size-lg);
  }

  /* ===== How It Works Flow ===== */
  .flow-steps {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-4);
    margin: var(--space-8) 0;
  }

  .flow-step {
    flex: 1;
    max-width: 200px;
    text-align: center;
  }

  .flow-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--space-3);
    background: var(--color-primary);
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }

  .flow-step h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .flow-step p {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .flow-arrow {
    display: flex;
    align-items: center;
    padding-top: var(--space-6);
    color: var(--color-primary);
    opacity: 0.5;
  }

  .flow-note {
    text-align: center;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .flow-steps {
      flex-direction: column;
      align-items: center;
    }

    .flow-arrow {
      transform: rotate(90deg);
      padding: var(--space-2) 0;
    }
  }

  /* ===== Audience Cards ===== */
  .audience-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .audience-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    transition: all var(--transition-fast);
  }

  .audience-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .audience-icon {
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    margin-bottom: var(--space-3);
  }

  .audience-card h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .audience-card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .audience-cards {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Feature Cards ===== */
  .feature-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    transition: all var(--transition-fast);
  }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .feature-card :global(.digi-icon) {
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .feature-card h3 {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    margin-bottom: var(--space-1);
    color: var(--color-text);
  }

  .feature-card p {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .feature-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .feature-cards {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Creator Card ===== */
  .creator-card {
    display: flex;
    gap: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    margin-top: var(--space-4);
  }

  .creator-avatar {
    flex-shrink: 0;
    align-self: center;
  }

  .digivice-glow {
    position: relative;
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .digivice-glow::before {
    content: '';
    position: absolute;
    inset: -12px;
    background: radial-gradient(circle, rgba(0, 200, 255, 0.4) 0%, rgba(0, 200, 255, 0) 70%);
    border-radius: 50%;
    animation: digivice-pulse 3s ease-in-out infinite;
  }

  .digivice-icon {
    width: 80px;
    height: 80px;
    position: relative;
    z-index: 1;
  }

  @keyframes digivice-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }

  .creator-info h3 {
    font-family: var(--font-family-display);
    font-size: var(--font-size-xl);
    color: var(--color-primary);
    margin-bottom: var(--space-1);
  }

  .creator-title {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .creator-info p {
    margin-bottom: var(--space-3);
  }

  .creator-note {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .creator-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  /* ===== Stats Grid ===== */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    margin: var(--space-6) 0;
  }

  .stat-item {
    text-align: center;
    padding: var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .stat-value {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--color-primary);
