---
// Minimal full-screen iframe wrapper for the Shiny app
// Served at app.digilab.cards

const IFRAME_SRC = 'https://019bfe6c-c032-7134-a060-84ceec5e089d.share.connect.posit.cloud/';
const IFRAME_ORIGIN = 'https://019bfe6c-c032-7134-a060-84ceec5e089d.share.connect.posit.cloud';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>DigiLab - Digimon TCG Locals Tracker</title>
  <meta name="description" content="Track local Digimon TCG tournament results, player standings, and deck meta.">

  <!-- PWA / iOS Home Screen -->
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="DigiLab">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#0A3055">

  <!-- Open Graph / Social Media -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://app.digilab.cards/">
  <meta property="og:title" content="DigiLab - Digimon TCG Locals Tracker">
  <meta property="og:description" content="Track local Digimon TCG tournament results, player standings, and deck meta.">
  <meta property="og:image" content="https://digilab.cards/images/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="DigiLab - Digimon TCG Locals Tracker">
  <meta name="twitter:description" content="Track local Digimon TCG tournament results, player standings, and deck meta.">
  <meta name="twitter:image" content="https://digilab.cards/images/og-image.png">

  <!-- PWA Manifest -->
  <link rel="manifest" href="/manifest.json">

  <!-- Favicon and app icons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <!-- GA removed from parent page — triggers Safari ITP tracker classification
       for digilab.cards, causing all storage (cookies, localStorage) to be evicted
       on browser close. The Shiny app inside the iframe has its own GA (app.R). -->

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      height: 100%;
      width: 100%;
      overflow: hidden;
      background: #0A3055;
    }
    iframe {
      position: absolute;
      top: env(safe-area-inset-top, 0px);
      left: env(safe-area-inset-left, 0px);
      width: calc(100% - env(safe-area-inset-left, 0px) - env(safe-area-inset-right, 0px));
      height: calc(100% - env(safe-area-inset-top, 0px) - env(safe-area-inset-bottom, 0px));
      border: none;
      display: block;
    }
    .fallback {
      display: none;
      text-align: center;
      padding: 50px 20px;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    .fallback a {
      color: #0A3055;
      font-size: 1.2em;
    }

    /* Cookie consent banner — click on parent page makes Safari ITP
       classify domain as interactive, preserving storage across sessions */
    .cookie-banner {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 10000;
      background: rgba(10, 48, 85, 0.97);
      color: #e0e0e0;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 13px;
      line-height: 1.4;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      border-top: 1px solid rgba(255,255,255,0.1);
    }
    .cookie-banner p {
      margin: 0;
      max-width: 480px;
    }
    .cookie-banner a {
      color: #7ec8e3;
      text-decoration: underline;
    }
    .cookie-banner button {
      flex-shrink: 0;
      background: #7ec8e3;
      color: #0A3055;
      border: none;
      border-radius: 6px;
      padding: 8px 20px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    .cookie-banner button:active {
      opacity: 0.85;
    }
    @media (max-width: 480px) {
      .cookie-banner {
        flex-direction: column;
        gap: 8px;
        padding: 10px 14px;
        font-size: 12px;
      }
      .cookie-banner button {
        width: 100%;
        padding: 10px;
      }
    }
  </style>
</head>
<body>
  <iframe
    id="digilab-iframe"
    src={IFRAME_SRC}
    title="DigiLab - Digimon TCG Locals Tracker"
    allow="fullscreen; clipboard-write; geolocation; webgl"
    loading="eager"
  ></iframe>

  <noscript>
    <div class="fallback" style="display: block;">
      <p>Please enable JavaScript or visit the app directly:</p>
      <a href={IFRAME_SRC}>Open DigiLab</a>
    </div>
  </noscript>

  <!-- Cookie consent banner — user click on parent page satisfies Safari ITP
       "user interaction" requirement, preventing storage eviction on browser close.
       Also future-proofs for EU scenes (GDPR). -->
  <div id="cookie-banner" class="cookie-banner" style="display:none;">
    <p>DigiLab uses cookies to remember your preferences (like your local scene). No tracking cookies are used on this page.</p>
    <button id="cookie-accept">Got it</button>
  </div>

  <script define:vars={{ IFRAME_ORIGIN }}>
    (function() {
      'use strict';

      var iframe = document.getElementById('digilab-iframe');
      var iframeReady = false;

      // Request persistent storage — prevents Safari ITP from evicting on browser close
      if (navigator.storage && navigator.storage.persist) {
        navigator.storage.persist();
      }

      // Cookie consent banner — show unless already accepted
      var CONSENT_COOKIE = 'digilab_cookie_consent';
      var banner = document.getElementById('cookie-banner');
      var acceptBtn = document.getElementById('cookie-accept');

      function hasConsent() {
        return document.cookie.indexOf(CONSENT_COOKIE + '=1') !== -1;
      }

      if (!hasConsent() && banner) {
        banner.style.display = 'flex';
      }

      if (acceptBtn) {
        acceptBtn.addEventListener('click', function() {
          // Set consent cookie — use .digilab.cards domain in production, omit for localhost
          var cookieStr = CONSENT_COOKIE + '=1; path=/; max-age=31536000; SameSite=Lax';
          if (window.location.hostname !== 'localhost') {
            cookieStr += '; domain=.digilab.cards; Secure';
          }
          document.cookie = cookieStr;
          banner.style.display = 'none';

          // Re-request persistent storage now that we have user interaction
          if (navigator.storage && navigator.storage.persist) {
            navigator.storage.persist();
          }
        });
      }

      // Cookie helpers — storage on .digilab.cards domain (persists across subdomains)
      var COOKIE_DOMAIN = '.digilab.cards';
      var COOKIE_MAX_AGE = 31536000; // 1 year

      function getCookie(name) {
        var match = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '=([^;]*)'));
        return match ? decodeURIComponent(match[1]) : null;
      }

      // Set cookie via server-side Set-Cookie header (immune to Safari ITP JS cookie eviction).
      // Falls back to document.cookie on localhost or if fetch fails.
      function setCookie(name, value) {
        console.log('[storage-bridge] setCookie', name, value);
        if (window.location.hostname === 'localhost') {
          document.cookie = name + '=' + encodeURIComponent(value)
            + '; path=/; max-age=' + COOKIE_MAX_AGE;
          return;
        }
        fetch('/__storage', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'set', key: name, value: value }),
          credentials: 'same-origin'
        }).catch(function() {
          // Fallback to document.cookie if fetch fails
          document.cookie = name + '=' + encodeURIComponent(value)
            + '; domain=' + COOKIE_DOMAIN
            + '; path=/; max-age=' + COOKIE_MAX_AGE
            + '; SameSite=Lax; Secure';
        });
      }

      function removeCookie(name) {
        if (window.location.hostname === 'localhost') {
          document.cookie = name + '=; path=/; max-age=0';
          return;
        }
        fetch('/__storage', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'remove', key: name }),
          credentials: 'same-origin'
        }).catch(function() {
          document.cookie = name + '=; domain=' + COOKIE_DOMAIN
            + '; path=/; max-age=0; SameSite=Lax; Secure';
        });
      }

      // Listen for messages from iframe
      window.addEventListener('message', function(event) {
        // Debug: log ALL messages before filtering (remove after ITP fix confirmed)
        if (event.data && event.data.type && event.data.type.indexOf('digilab') === 0) {
          console.log('[bridge-raw]', event.data.type, 'origin:', event.origin, 'expected:', IFRAME_ORIGIN);
        }

        if (event.origin !== IFRAME_ORIGIN) return;
        if (!event.data || !event.data.type) return;

        switch (event.data.type) {
          case 'digilab-iframe-ready':
            // Iframe is ready, send initial URL if we have params
            iframeReady = true;
            var initialSearch = window.location.search;
            if (initialSearch) {
              iframe.contentWindow.postMessage({
                type: 'digilab-initial-url',
                search: initialSearch
              }, IFRAME_ORIGIN);
            }
            break;

          case 'digilab-url-update':
            // Iframe is updating the URL
            var url = event.data.url || '';
            var replace = event.data.replace || false;
            var newUrl = url || window.location.pathname;

            if (replace) {
              history.replaceState({ search: url }, '', newUrl);
            } else {
              if (window.location.search !== url) {
                history.pushState({ search: url }, '', newUrl);
              }
            }
            break;

          // Storage bridge — uses cookies on .digilab.cards domain
          // Safari ITP evicts localStorage for app.digilab.cards because all
          // user interaction goes to the cross-origin iframe. Cookies on the
          // parent domain (.digilab.cards) persist reliably — Safari already
          // preserves 671 KB of data for digilab.cards.
          case 'digilab-storage-get':
            event.source.postMessage({
              type: 'digilab-storage-result',
              requestId: event.data.requestId,
              value: getCookie(event.data.key)
            }, event.origin);
            break;

          case 'digilab-storage-set':
            setCookie(event.data.key, event.data.value);
            event.source.postMessage({
              type: 'digilab-storage-result',
              requestId: event.data.requestId,
              value: null
            }, event.origin);
            break;

          case 'digilab-storage-remove':
            removeCookie(event.data.key);
            event.source.postMessage({
              type: 'digilab-storage-result',
              requestId: event.data.requestId,
              value: null
            }, event.origin);
            break;
        }
      });

      // Handle browser back/forward
      window.addEventListener('popstate', function(event) {
        var search = window.location.search;
        if (iframeReady) {
          iframe.contentWindow.postMessage({
            type: 'digilab-url-navigate',
            search: search
          }, IFRAME_ORIGIN);
        }
      });
    })();
  </script>
</body>
</html>
