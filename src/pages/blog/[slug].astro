---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const categoryLabels: Record<string, string> = {
  announcement: 'Announcements',
  technical: 'Technical',
  analysis: 'Analysis',
  spotlight: 'Spotlight',
  devlog: 'Dev Log',
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <Header />

  <main class="post-page">
    <article class="container">
      <header class="post-header">
        <div class="post-meta">
          <span class={`category category-${post.data.category}`}>
            {categoryLabels[post.data.category]}
          </span>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
          <span class="author">by {post.data.author}</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
      </header>

      {post.data.image && (
        <img src={post.data.image} alt="" class="post-hero-image" />
      )}

      <div class="post-content prose">
        <Content />
      </div>

      <footer class="post-footer">
        <a href="/blog" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7"></path>
            <path d="M19 12H5"></path>
          </svg>
          Back to Blog
        </a>
      </footer>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .post-page {
    padding: var(--space-12) 0;
  }

  .post-page .container {
    max-width: 800px;
  }

  .post-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    font-size: var(--font-size-sm);
    flex-wrap: wrap;
  }

  .category {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    font-size: var(--font-size-xs);
    letter-spacing: 0.05em;
  }

  .category-announcement { background-color: #e3f2fd; color: #1565c0; }
  .category-technical { background-color: #f3e5f5; color: #7b1fa2; }
  .category-analysis { background-color: #e8f5e9; color: #2e7d32; }
  .category-spotlight { background-color: #fff3e0; color: #ef6c00; }
  .category-devlog { background-color: #fce4ec; color: #c2185b; }

  time, .author {
    color: var(--color-text-muted);
  }

  .post-header h1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-4);
  }

  .post-description {
    font-size: var(--font-size-lg);
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .post-hero-image {
    width: 100%;
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  /* Prose styles for content */
  .prose {
    line-height: var(--line-height-relaxed);
  }

  .prose :global(h2) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .prose :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .prose :global(p) {
    margin-bottom: var(--space-4);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }

  .post-footer {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-muted);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
  }

  .back-link:hover {
    color: var(--color-accent);
  }
</style>
