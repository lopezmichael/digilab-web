---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DigiIcon from '../../components/DigiIcon.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// Get all posts for prev/next navigation
const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const currentIndex = allPosts.findIndex(p => p.slug === post.slug);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const categoryLabels: Record<string, string> = {
  announcement: 'Announcements',
  technical: 'Technical',
  analysis: 'Analysis',
  spotlight: 'Spotlight',
  devlog: 'Dev Log',
};

const categoryIcons: Record<string, string> = {
  announcement: 'megaphone',
  technical: 'code-slash',
  analysis: 'graph-up',
  spotlight: 'star',
  devlog: 'journal-code',
};

// Filter headings for TOC (h2 and h3 only)
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
>
  <Header />

  <main class="post-page">
    <!-- Hero Section -->
    <section class="post-hero">
      <div class="hero-bg"></div>
      <div class="hero-fade"></div>
      <div class="container hero-content">
        <a href="/blog" class="back-to-blog">
          <i class="bi bi-arrow-left"></i>
          Back to Blog
        </a>

        <div class="post-meta">
          <span class={`category category-${post.data.category}`}>
            <i class={`bi bi-${categoryIcons[post.data.category]}`}></i>
            {categoryLabels[post.data.category]}
          </span>
          <span class="meta-separator">•</span>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>
        </div>

        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>

        <div class="post-info-row">
          <div class="post-author">
            <i class="bi bi-person-circle"></i>
            <span>by <strong>{post.data.author}</strong></span>
          </div>

          {post.data.tags && post.data.tags.length > 0 && (
            <div class="post-tags">
              {post.data.tags.map((tag: string) => (
                <a href={`/blog?tag=${tag}`} class="tag">
                  <i class="bi bi-hash"></i>{tag}
                </a>
              ))}
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- Main Content Area -->
    <div class="container content-container">
      <div class="content-layout">
        <!-- Table of Contents (Desktop) -->
        {tocHeadings.length > 3 && (
          <aside class="toc-sidebar">
            <nav class="toc" aria-label="Table of contents">
              <h4>On this page</h4>
              <ul>
                {tocHeadings.map((heading) => (
                  <li class={heading.depth === 3 ? 'toc-sub' : ''}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}

        <!-- Article Content -->
        <article class="post-article">
          <div class="prose">
            <Content />
          </div>

          <!-- Post Footer -->
          <footer class="post-footer">
            <div class="share-section">
              <span class="share-label">Share this post</span>
              <div class="share-buttons">
                <a
                  href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(`https://digilab.cards/blog/${post.slug}`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="share-btn"
                  title="Share on X"
                >
                  <i class="bi bi-twitter-x"></i>
                </a>
                <button
                  class="share-btn"
                  id="copy-link-btn"
                  data-url={`https://digilab.cards/blog/${post.slug}`}
                  title="Copy link"
                >
                  <i class="bi bi-link-45deg"></i>
                </button>
              </div>
            </div>

            {(prevPost || nextPost) && (
              <nav class="post-nav" aria-label="Post navigation">
                {prevPost ? (
                  <a href={`/blog/${prevPost.slug}`} class="post-nav-link prev">
                    <span class="nav-direction">
                      <i class="bi bi-arrow-left"></i> Previous
                    </span>
                    <span class="nav-title">{prevPost.data.title}</span>
                  </a>
                ) : <div></div>}
                {nextPost && (
                  <a href={`/blog/${nextPost.slug}`} class="post-nav-link next">
                    <span class="nav-direction">
                      Next <i class="bi bi-arrow-right"></i>
                    </span>
                    <span class="nav-title">{nextPost.data.title}</span>
                  </a>
                )}
              </nav>
            )}
          </footer>
        </article>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ===== Hero Section ===== */
  .post-hero {
    position: relative;
    padding: var(--space-8) 0 var(--space-12);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary-dark, #061a2e) 0%, var(--color-primary) 100%);
    z-index: -2;
  }

  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -80px;
    height: 100px;
    background: linear-gradient(to bottom, transparent 0%, var(--color-background) 100%);
    z-index: -1;
  }

  .hero-content {
    position: relative;
    max-width: 800px;
  }

  .back-to-blog {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-6);
    transition: color var(--transition-fast);
  }

  .back-to-blog:hover {
    color: #ffffff;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .meta-separator {
    color: rgba(255, 255, 255, 0.4);
  }

  .category {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .category-announcement { background: rgba(21, 101, 192, 0.3); color: #90caf9; }
  .category-technical { background: rgba(123, 31, 162, 0.3); color: #ce93d8; }
  .category-analysis { background: rgba(46, 125, 50, 0.3); color: #a5d6a7; }
  .category-spotlight { background: rgba(239, 108, 0, 0.3); color: #ffcc80; }
  .category-devlog { background: rgba(194, 24, 91, 0.3); color: #f48fb1; }

  time {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--font-size-sm);
  }

  .hero-content h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: #ffffff;
    margin-bottom: var(--space-3);
    line-height: 1.25;
  }

  .post-description {
    font-size: var(--font-size-sm);
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: var(--space-4);
    line-height: var(--line-height-relaxed);
  }

  .post-info-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: rgba(255, 255, 255, 0.8);
    font-size: var(--font-size-sm);
  }

  .post-author i {
    font-size: 1.1rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: var(--space-1) var(--space-2);
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .tag:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  /* ===== Content Layout ===== */
  .content-container {
    padding-top: var(--space-8);
    padding-bottom: var(--space-12);
  }

  .content-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 1100px) {
    .content-layout {
      grid-template-columns: 1fr 220px;
      max-width: 1100px;
    }

    .toc-sidebar {
      order: 1;
    }

    .post-article {
      order: 0;
    }
  }

  /* ===== Table of Contents ===== */
  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1100px) {
    .toc-sidebar {
      display: block;
    }
  }

  .toc {
    position: sticky;
    top: var(--space-8);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .toc h4 {
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li {
    margin-bottom: var(--space-1);
  }

  .toc a {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    padding: var(--space-1) 0;
    transition: color var(--transition-fast);
    line-height: 1.4;
  }

  .toc a:hover {
    color: var(--color-primary);
  }

  .toc .toc-sub a {
    padding-left: var(--space-3);
    font-size: var(--font-size-xs);
  }

  /* ===== Article ===== */
  .post-article {
    min-width: 0;
  }

  /* ===== Prose (Content) Styles ===== */
  .prose {
    line-height: var(--line-height-relaxed);
    color: var(--color-text);
  }

  .prose :global(h2) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    font-size: var(--font-size-2xl);
    scroll-margin-top: var(--space-8);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-border);
  }

  .prose :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    font-size: var(--font-size-xl);
    scroll-margin-top: var(--space-8);
  }

  .prose :global(p) {
    margin-bottom: var(--space-4);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(strong) {
    font-weight: var(--font-weight-semibold);
  }

  /* Blockquotes */
  .prose :global(blockquote) {
    position: relative;
    margin: var(--space-6) 0;
    padding: var(--space-5) var(--space-6);
    background: linear-gradient(135deg, rgba(10, 48, 85, 0.06) 0%, rgba(247, 148, 29, 0.04) 100%);
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  /* TL;DR Card Style */
  .prose :global(#tldr) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: linear-gradient(135deg, var(--color-primary) 0%, rgba(10, 48, 85, 0.9) 100%);
    color: #ffffff;
    border-radius: var(--radius-md);
    font-size: var(--font-size-lg);
  }

  .prose :global(#tldr + ul) {
    margin-top: 0;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-8);
    background: rgba(10, 48, 85, 0.04);
    border: 1px solid rgba(10, 48, 85, 0.1);
    border-radius: var(--radius-md);
    list-style: none;
  }

  .prose :global(#tldr + ul li) {
    position: relative;
    padding-left: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .prose :global(#tldr + ul li::before) {
    content: '▶';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.6em;
    top: 0.45em;
  }

  .prose :global(#tldr + ul li:last-child) {
    margin-bottom: 0;
  }

  /* Tables - Compact */
  .prose :global(table) {
    width: 100%;
    margin: var(--space-6) 0;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .prose :global(thead) {
    background: var(--color-primary);
  }

  .prose :global(th) {
    padding: var(--space-2) var(--space-3);
    text-align: left;
    font-weight: var(--font-weight-semibold);
    color: #ffffff;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose :global(td) {
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .prose :global(tbody tr:hover) {
    background: rgba(10, 48, 85, 0.03);
  }

  /* Inline code */
  .prose :global(code) {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    padding: 0.15em 0.4em;
    background: rgba(10, 48, 85, 0.08);
    border-radius: var(--radius-sm);
    color: var(--color-primary);
  }

  /* Code blocks */
  .prose :global(pre) {
    margin: var(--space-6) 0;
    padding: var(--space-4);
    background: #1e1e2e;
    border-radius: var(--radius-md);
    overflow-x: auto;
  }

  .prose :global(pre code) {
    padding: 0;
    background: none;
    color: #cdd6f4;
    font-size: var(--font-size-sm);
  }

  /* Links */
  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-underline-offset: 3px;
    transition: all var(--transition-fast);
  }

  .prose :global(a:hover) {
    color: var(--color-accent);
  }

  /* Horizontal rule */
  .prose :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-border), transparent);
    margin: var(--space-8) 0;
  }

  /* ===== Post Footer ===== */
  .post-footer {
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .share-section {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .share-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .share-buttons {
    display: flex;
    gap: var(--space-2);
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
    text-decoration: none;
    font-size: 1rem;
  }

  .share-btn:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #ffffff;
  }

  /* Post Navigation */
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .post-nav-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }

  .post-nav-link.prev {
    text-align: left;
  }

  .post-nav-link.next {
    text-align: right;
  }

  .nav-direction {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-nav-link.next .nav-direction {
    justify-content: flex-end;
  }

  .nav-title {
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    line-height: 1.4;
  }

  .post-nav-link:hover .nav-title {
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
  }

  /* ===== Dark Mode ===== */
  :global([data-theme="dark"]) .hero-fade {
    background: linear-gradient(to bottom, transparent 0%, var(--color-background-dark, #0a0a0a) 100%);
  }

  :global([data-theme="dark"]) .toc {
    background: var(--color-surface-dark);
    border-color: var(--color-border-dark);
  }

  :global([data-theme="dark"]) .prose :global(blockquote) {
    background: linear-gradient(135deg, rgba(0, 200, 255, 0.06) 0%, rgba(247, 148, 29, 0.04) 100%);
  }

  :global([data-theme="dark"]) .prose :global(code) {
    background: rgba(0, 200, 255, 0.12);
    color: var(--color-digital);
  }

  :global([data-theme="dark"]) .prose :global(thead) {
    background: rgba(0, 200, 255, 0.2);
  }

  :global([data-theme="dark"]) .prose :global(tbody tr:hover) {
    background: rgba(0, 200, 255, 0.05);
  }

  :global([data-theme="dark"]) .prose :global(#tldr) {
    background: linear-gradient(135deg, rgba(0, 200, 255, 0.25) 0%, rgba(0, 200, 255, 0.15) 100%);
    color: var(--color-digital);
  }

  :global([data-theme="dark"]) .prose :global(#tldr + ul) {
    background: rgba(0, 200, 255, 0.05);
    border-color: rgba(0, 200, 255, 0.15);
  }

  :global([data-theme="dark"]) .post-nav-link,
  :global([data-theme="dark"]) .share-btn {
    background: var(--color-surface-dark);
    border-color: var(--color-border-dark);
  }
</style>

<script>
  // Copy link functionality
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const url = copyBtn.getAttribute('data-url');
      if (url) {
        try {
          await navigator.clipboard.writeText(url);
          const icon = copyBtn.querySelector('i');
          if (icon) {
            icon.className = 'bi bi-check';
            setTimeout(() => {
              icon.className = 'bi bi-link-45deg';
            }, 2000);
          }
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      }
    });
  }
</script>
