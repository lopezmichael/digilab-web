---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categoryLabels: Record<string, string> = {
  announcement: 'Announcements',
  technical: 'Technical',
  analysis: 'Analysis',
  spotlight: 'Spotlight',
  devlog: 'Dev Log',
};
---

<BaseLayout title="Blog" description="Updates, analysis, and insights from the DigiLab team.">
  <Header />

  <main class="blog-page">
    <div class="container">
      <header class="page-header">
        <h1>Blog</h1>
        <p>Updates, analysis, and insights from the DigiLab team.</p>
      </header>

      {posts.length === 0 ? (
        <div class="empty-state">
          <p>No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="posts-grid">
          {posts.map((post) => (
            <article class="post-card card">
              {post.data.image && (
                <img src={post.data.image} alt="" class="post-image" />
              )}
              <div class="post-content">
                <div class="post-meta">
                  <span class={`category category-${post.data.category}`}>
                    {categoryLabels[post.data.category]}
                  </span>
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </div>
                <h2 class="post-title">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h2>
                <p class="post-description">{post.data.description}</p>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-page {
    padding: var(--space-12) 0;
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .page-header h1 {
    margin-bottom: var(--space-4);
  }

  .page-header p {
    color: var(--color-text-muted);
    font-size: var(--font-size-lg);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-16) 0;
    color: var(--color-text-muted);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .post-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .post-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .post-content {
    padding: var(--space-6);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-size: var(--font-size-sm);
  }

  .category {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    font-size: var(--font-size-xs);
    letter-spacing: 0.05em;
  }

  .category-announcement {
    background-color: #e3f2fd;
    color: #1565c0;
  }

  .category-technical {
    background-color: #f3e5f5;
    color: #7b1fa2;
  }

  .category-analysis {
    background-color: #e8f5e9;
    color: #2e7d32;
  }

  .category-spotlight {
    background-color: #fff3e0;
    color: #ef6c00;
  }

  .category-devlog {
    background-color: #fce4ec;
    color: #c2185b;
  }

  time {
    color: var(--color-text-muted);
  }

  .post-title {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-2);
  }

  .post-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .post-title a:hover {
    color: var(--color-accent);
  }

  .post-description {
    color: var(--color-text-muted);
    margin: 0;
    flex: 1;
  }
</style>
